# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Diagnostic reports (https://nodejs.org/api/report.html)
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov

# Coverage directory used by tools like istanbul
coverage
*.lcov

# nyc test coverage
.nyc_output

# Grunt intermediate storage (https://gruntjs.com/creating-plugins#storing-task-files)
.grunt

# Bower dependency directory (https://bower.io/)
bower_components

# node-gyp builds
build/Release

# Dependency directories
node_modules/
jspm_packages/

# Snowpack dependency directory (https://snowpack.dev/)
web_modules/

# TypeScript cache
*.tsbuildinfo

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Optional stylelint cache
.stylelintcache

# Microbundle cache
.rts2_cache_main
.rts2_cache_lit
.rts2_cache_api

# Directory for user-specific files
.env
.env.development.local
.env.test.local
.env.production.local
.env.local
.env*.local

# Stores VS Code settings, but usually personal preferences shouldn't be committed
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/projects.json
.history/
*.code-workspace

# JetBrains IDEs
.idea/

# OS Files
.DS_Store
Thumbs.db

# --- Project-Specific Ignores ---

# Vite build/dist directory
dist/
dist-ssr/
dist-chrome/
dist-firefox/
*.local

# Chrome / Web Extension builds & keys (CRITICAL: Do not leak private key .pem files!)
*.pem
*.crx
*.zip

# Temporary build & timestamp files from Vite
vite.config.ts.timestamp-*

# Project temporary analysis/split folders
temp_acs_split/
